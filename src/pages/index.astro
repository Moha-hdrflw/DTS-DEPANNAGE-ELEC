<style>
  /* Mobile defaults: hide text prefixes */
  .nav-phone-hide  { display: none; }
  .hero-cta-prefix { display: none; }

  /* Zone & avis cards: full width on mobile */
  .zone-card, .avis-card { width: 100%; }

  /* Tablet 560px+: 2 columns for engagements; zones & avis go 2-wide */
  @media (min-width: 560px) {
    .engagements-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .zone-card        { width: calc(50% - 0.5rem); }
    .avis-card        { width: calc(50% - 0.5rem); }
  }

  /* Desktop 700px+: show nav links, 2-col hero, hero photo, hide mobile photo */
  @media (min-width: 700px) {
    .footer-mobile-nav { display: none !important; }
    .nav-links         { display: flex !important; }
    .hero-cta-prefix   { display: inline !important; }
    .hero-grid         { grid-template-columns: 1fr 1fr !important; }
    .hero-text         { text-align: left !important; }
    .hero-photo        { display: block !important; }
    .hero-photo-mobile { display: none !important; }
    .stats-grid        { margin: 0 !important; }
    .engagements-grid  { grid-template-columns: repeat(2, 1fr) !important; }
    .photos-grid       { grid-template-columns: repeat(3, 1fr) !important; }
    .sep-desktop       { display: inline !important; }
    /* Zones: 3 per row, last row centred */
    .zone-card { width: calc(33.333% - 0.667rem); }
    /* Avis: 2 per row, last item centred */
    .avis-card { width: calc(50% - 0.5rem); }
  }

  /* Wide desktop 900px+: show "Appeler —" in nav, 3-col services */
  @media (min-width: 900px) {
    .nav-phone-hide  { display: inline !important; }
    .services-grid   { grid-template-columns: repeat(3, 1fr) !important; }
  }
</style>
