---
import Layout from '../layouts/Layout.astro';

// ⚠️  À compléter par le client
const PHONE_DISPLAY = "06 XX XX XX XX";
const PHONE_TEL     = "tel:+3306XXXXXXXX";
const WHATSAPP_URL  = "https://wa.me/336XXXXXXXX";

const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Panne générale",
    desc: "Coupure totale, tableau en défaut, disjoncteur principal sauté.",
    price: "Dès 75 €",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round" stroke-width="3"/></svg>`,
    title: "Disjoncteur sauté",
    desc: "Disjoncteur différentiel, sectionneur, protection qui disjoncte.",
    price: "Dès 75 €",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="8" y1="8" x2="8" y2="16"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="16" y1="8" x2="16" y2="16"/></svg>`,
    title: "Tableau électrique",
    desc: "Remplacement tableau, mise aux normes, ajout de protection.",
    price: "Dès 130 €",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
    title: "Prises & éclairage",
    desc: "Prise HS, court-circuit, ampoule, interrupteur défaillant.",
    price: "Dès 75 €",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Mise en sécurité",
    desc: "Installation dangereuse, risque d'électrocution ou d'incendie.",
    price: "Dès 130 €",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    title: "Urgence pro",
    desc: "Hôtels, restaurants, copropriétés — intervention prioritaire.",
    price: "Dès 75 €",
  },
];

const engagements = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
    title: "Tarif affiché",
    desc: "Prix HT communiqués avant l'intervention. Zéro surprise sur la facture.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>`,
    title: "Devis avant travaux",
    desc: "Devis signé systématiquement avant toute intervention.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
    title: "Suivi J+1",
    desc: "Rappel le lendemain pour s'assurer que tout est en ordre.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#b8d400" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Intervention rapide",
    desc: "Réponse immédiate 24h/24 — 7j/7, jours fériés inclus.",
  },
];

const zones = [
  { region: "Pays de Gex (01)", villes: ["Gex", "Ferney-Voltaire", "Saint-Genis-Pouilly", "Thoiry", "Divonne-les-Bains"] },
  { region: "Annemasse +40 km (74)", villes: ["Annemasse", "Ville-la-Grand", "Cranves-Sales", "Saint-Julien-en-Genevois"] },
  { region: "Thonon-les-Bains +20 km (74)", villes: ["Thonon-les-Bains", "Douvaine", "Sciez"] },
  { region: "Annecy +40 km (74)", villes: ["Annecy", "Cran-Gevrier", "Seynod"] },
  { region: "Bellegarde +20 km (01)", villes: ["Bellegarde-sur-Valserine", "Châtillon-en-Michaille"] },
];

const tarifsJournee = [
  { prestation: "Déplacement",               prix: "75 € HT" },
  { prestation: "Recherche de panne",         prix: "195 € HT" },
  { prestation: "Main d'œuvre / heure",       prix: "90 € HT" },
  { prestation: "Mise en sécurité électrique",prix: "130 € HT" },
];

const tarifsNuit = [
  { prestation: "Déplacement",               prix: "115 € HT" },
  { prestation: "Recherche de panne",         prix: "230 € HT" },
  { prestation: "Main d'œuvre / heure",       prix: "150 € HT" },
  { prestation: "Mise en sécurité électrique",prix: "145 € HT" },
];

const avis = [
  {
    nom: "Marc D.",
    ville: "Ferney-Voltaire",
    note: 5,
    texte: "Intervention rapide un dimanche soir. Tableau HS, réglé en moins d'une heure. Tarif annoncé respecté, aucune surprise.",
  },
  {
    nom: "Sophie L.",
    ville: "Annemasse",
    note: 5,
    texte: "Très professionnel. Diagnostic précis, devis signé avant de commencer. Je recommande sans hésiter pour toute urgence électrique.",
  },
  {
    nom: "Karim B.",
    ville: "Thonon-les-Bains",
    note: 5,
    texte: "Disjoncteur différentiel remplacé rapidement. Technicien sérieux, explication claire du problème. Rappel le lendemain pour confirmer que tout allait bien.",
  },
];
---

<Layout
  title="Électricien Urgence Pays de Gex Annemasse — DTS Dépannage Elec | 24h/24"
  description="Électricien urgence dans le Pays de Gex, Annemasse, Annecy et Thonon ? DTS Dépannage Elec intervient rapidement 24h/24 7j/7. Tarif affiché, devis avant travaux."
>

  <!-- =========================================================
       1. BARRE URGENCE STICKY
       ========================================================= -->
  <div
    id="urgence-bar"
    style="position:sticky;top:0;z-index:50;background:rgba(6,13,22,0.97);border-bottom:1px solid rgba(184,212,0,0.25);backdrop-filter:blur(8px);"
  >
    <div style="max-width:1200px;margin:0 auto;padding:0.55rem 1rem;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0.5rem 1.25rem;text-align:center;">
      <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:#c8e0c8;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;">Disponible 24h/24 — 7j/7</span>
      </span>
      <span style="color:#4a7a5a;font-size:0.8rem;display:none;" class="sep-desktop">|</span>
      <span style="font-size:0.8rem;color:#c8e0c8;">⚡ Intervention rapide</span>
      <span style="color:#4a7a5a;font-size:0.8rem;display:none;" class="sep-desktop">|</span>
      <span style="font-size:0.8rem;color:#c8e0c8;">Pays de Gex · Annemasse · Annecy · Thonon</span>
      <a
        href={PHONE_TEL}
        style="background:#b8d400;color:#060d16;font-weight:800;padding:0.3rem 0.85rem;border-radius:0.4rem;font-size:0.82rem;text-decoration:none;white-space:nowrap;box-shadow:0 0 12px rgba(184,212,0,0.45);"
      >
        📞 {PHONE_DISPLAY}
      </a>
    </div>
  </div>

  <!-- =========================================================
       2. NAVIGATION
       ========================================================= -->
  <nav
    style="background:rgba(6,13,22,0.95);border-bottom:1px solid rgba(184,212,0,0.08);backdrop-filter:blur(8px);"
  >
    <div
      style="max-width:1200px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;"
    >
      <!-- Logo -->
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="54" height="42" style="width:54px;height:42px;object-fit:contain;display:block;transform:translateY(-2px);" />
        </div>
        <div>
          <div style="color:#b8d400;font-weight:800;font-size:0.95rem;line-height:1.1;text-shadow:0 0 8px rgba(184,212,0,0.6);">DTS Dépannage</div>
          <div style="color:#4a7a5a;font-size:0.72rem;line-height:1;">Elec · 24h/24</div>
        </div>
      </a>

      <!-- Links desktop -->
      <div style="display:none;gap:1.5rem;align-items:center;" class="nav-links">
        <a href="/depannage-electricite/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;transition:color 0.2s;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Dépannage</a>
        <a href="/tarifs/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;transition:color 0.2s;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Tarifs</a>
        <a href="/zones/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;transition:color 0.2s;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Zones</a>
        <a href="/contact/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;transition:color 0.2s;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Contact</a>
      </div>

      <!-- CTA nav -->
      <a
        href={PHONE_TEL}
        class="btn-cta"
        style="padding:0.6rem 1rem;font-size:0.85rem;white-space:nowrap;flex-shrink:0;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="nav-phone-hide">Appeler — </span>{PHONE_DISPLAY}
      </a>
    </div>
  </nav>

  <!-- =========================================================
       3. HERO
       ========================================================= -->
  <section
    style="position:relative;overflow:hidden;padding:3.5rem 1.25rem 4rem;background:linear-gradient(160deg,#060d16 0%,#071408 60%,#060d16 100%);"
  >
    <!-- Lightning bolts background decoration -->
    <svg class="bolt-bg" style="top:8%;left:6%;opacity:0.05;animation-delay:0s;" width="60" height="100" viewBox="0 0 60 100" fill="#b8d400"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <svg class="bolt-bg" style="top:15%;right:8%;opacity:0.04;animation-delay:2s;transform:rotate(10deg);" width="44" height="74" viewBox="0 0 60 100" fill="#4ab3ff"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <svg class="bolt-bg" style="bottom:20%;left:3%;opacity:0.04;animation-delay:4s;transform:rotate(-25deg);" width="36" height="60" viewBox="0 0 60 100" fill="#b8d400"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <svg class="bolt-bg" style="bottom:10%;right:5%;opacity:0.03;animation-delay:1s;" width="50" height="84" viewBox="0 0 60 100" fill="#4ab3ff"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>

    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:2.5rem;align-items:center;" class="hero-grid">

      <!-- Left: text -->
      <div style="text-align:center;" class="hero-text">

        <!-- Badge disponible -->
        <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(184,212,0,0.08);border:1px solid rgba(184,212,0,0.3);border-radius:2rem;padding:0.45rem 1rem;margin-bottom:1.5rem;">
          <span class="pulse-dot"></span>
          <span style="color:#b8d400;font-weight:700;font-size:0.88rem;text-shadow:0 0 8px rgba(184,212,0,0.7);">Disponible maintenant — Réponse immédiate</span>
        </div>

        <!-- H1 -->
        <h1 style="font-size:clamp(1.75rem,5vw,3rem);font-weight:900;line-height:1.15;margin:0 0 1rem;color:#f0f8f0;">
          Électricien urgence<br>
          <span class="neon-green">Pays de Gex · Annemasse</span><br>
          <span style="color:#4ab3ff;text-shadow:0 0 10px rgba(74,179,255,0.6);">Annecy · Thonon</span>
        </h1>

        <p style="font-size:1.05rem;color:#8ab89a;margin:0 0 2rem;line-height:1.6;max-width:520px;margin-left:auto;margin-right:auto;">
          Intervention rapide 24h/24 — 7j/7. Tarif affiché dès le 1er appel.
          Devis signé avant tous travaux. <strong style="color:#c8e0c8;">Zéro surprise.</strong>
        </p>

        <!-- CTA buttons -->
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;margin-bottom:2.5rem;">
          <a href={PHONE_TEL} class="btn-cta" style="font-size:1.15rem;padding:1.1rem 2rem;white-space:nowrap;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="hero-cta-prefix">Appelez maintenant — </span>{PHONE_DISPLAY}
          </a>
          <a href={WHATSAPP_URL} class="btn-whatsapp" style="font-size:1.05rem;padding:1.1rem 1.75rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.104 1.524 5.828L.057 23.5l5.83-1.449A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.848 0-3.574-.504-5.055-1.383l-.363-.215-3.754.932.975-3.651-.236-.376A9.948 9.948 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <!-- Photo mobile (sous WhatsApp, cachée sur desktop) -->
        <div class="hero-photo-mobile" style="margin-bottom:2rem;">
          <img
            src="/images/technicien.png"
            alt="Technicien électricien DTS en intervention"
            style="width:100%;aspect-ratio:1/1;object-fit:cover;object-position:center top;border-radius:1rem;border:2px solid rgba(184,212,0,0.2);box-shadow:0 0 24px rgba(184,212,0,0.1);"
          />
        </div>

        <!-- 4 stats -->
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.75rem;max-width:460px;margin:0 auto;" class="stats-grid">
          {[
            { icon: "⚡", val: "Intervention rapide", sub: "Dès votre appel" },
            { icon: "🕐", val: "24h/24 — 7j/7",      sub: "Jours fériés inclus" },
            { icon: "📋", val: "Tarif affiché",        sub: "Zéro surprise" },
            { icon: "💳", val: "CB + Espèces",          sub: "TPE" },
          ].map(s => (
            <div style="background:rgba(184,212,0,0.06);border:1px solid rgba(184,212,0,0.15);border-radius:0.625rem;padding:0.75rem;text-align:center;">
              <div style="font-size:1.4rem;margin-bottom:0.25rem;">{s.icon}</div>
              <div style="color:#b8d400;font-weight:700;font-size:0.85rem;text-shadow:0 0 6px rgba(184,212,0,0.5);">{s.val}</div>
              <div style="color:#4a7a5a;font-size:0.75rem;margin-top:0.1rem;">{s.sub}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: photo technicien (desktop only) -->
      <div class="hero-photo" style="display:none;">
        <img
          src="/images/technicien.png"
          alt="Technicien électricien DTS en intervention"
          style="width:100%;aspect-ratio:1/1;object-fit:cover;object-position:center top;border-radius:1rem;border:2px solid rgba(184,212,0,0.2);box-shadow:0 0 30px rgba(184,212,0,0.1);"
        />
      </div>

    </div>
  </section>

  <!-- =========================================================
       4. NOS INTERVENTIONS
       ========================================================= -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">DÉPANNAGE UNIQUEMENT</p>
        <a href="/depannage-electricite/" style="text-decoration:none;"><h2 class="section-title" style="cursor:pointer;">Nos interventions</h2></a>
        <p style="color:#6a9a7a;font-size:0.95rem;max-width:500px;margin:0.5rem auto 0;">
          Tous types de pannes électriques — logements, locaux professionnels, copropriétés.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="services-grid">
        {services.map(s => (
          <div class="card" style="padding:1.25rem;">
            <div style="margin-bottom:0.75rem;" set:html={s.icon} />
            <h3 style="color:#f0f8f0;font-size:1rem;font-weight:700;margin:0 0 0.35rem;">{s.title}</h3>
            <p style="color:#6a9a7a;font-size:0.82rem;margin:0;line-height:1.5;">{s.desc}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:2rem;">
        <a href={PHONE_TEL} class="btn-cta">
          Appelez maintenant — {PHONE_DISPLAY}
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================================
       5. PHOTOS (placeholders)
       ========================================================= -->
  <section style="padding:3rem 1.25rem;background:linear-gradient(180deg,#060d16 0%,#040c0a 100%);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2rem;">
        <h2 class="section-title">On s'occupe de tout !</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;" class="photos-grid">
        {[
          { src: "/images/dts-casquette.png",     alt: "Casquette DTS et matériel électricien professionnel",      pos: "center center" },
          { src: "/images/electricien-2.png",    alt: "Gros plan mains d'électricien sur boîtier électrique",    pos: "center center" },
