---
import Layout from '../../layouts/Layout.astro';

const PHONE_DISPLAY = "09 80 80 25 21";
const PHONE_TEL     = "tel:0980802521";

const tarifsJournee = [
  { prestation: "Déplacement",                prix: "75 € HT" },
  { prestation: "Recherche de panne",          prix: "195 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "90 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "130 € HT" },
];

const tarifsNuit = [
  { prestation: "Déplacement",                prix: "115 € HT" },
  { prestation: "Recherche de panne",          prix: "230 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "150 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "145 € HT" },
];
---

<Layout
  title="Tarifs Électricien Urgence — DTS Dépannage Elec | Prix HT Affichés"
  description="Tarifs clairs et affichés pour dépannage électrique urgence. Journée 7h-19h et nuit 19h-7h. Devis signé avant intervention. DTS Dépannage Elec."
>

  <!-- BARRE URGENCE -->
  <div style="position:sticky;top:0;z-index:50;background:rgba(6,13,22,0.97);border-bottom:1px solid rgba(184,212,0,0.25);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.55rem 1rem;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0.5rem 1.25rem;text-align:center;">
      <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:#c8e0c8;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;">Disponible 24h/24 — 7j/7</span>
      </span>
      <span style="font-size:0.8rem;color:#c8e0c8;">⚡ Intervention rapide</span>
      <span style="font-size:0.8rem;color:#c8e0c8;">Pays de Gex · Annemasse · Annecy · Thonon</span>
      <a href={PHONE_TEL} style="background:#b8d400;color:#060d16;font-weight:800;padding:0.3rem 0.85rem;border-radius:0.4rem;font-size:0.82rem;text-decoration:none;white-space:nowrap;box-shadow:0 0 12px rgba(184,212,0,0.45);">
        📞 {PHONE_DISPLAY}
      </a>
    </div>
  </div>

  <!-- NAVIGATION -->
  <nav style="background:rgba(6,13,22,0.95);border-bottom:1px solid rgba(184,212,0,0.08);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="54" height="42" style="width:54px;height:42px;object-fit:contain;display:block;transform:translateY(-2px);" />
        </div>
        <div>
          <div style="color:#b8d400;font-weight:800;font-size:0.95rem;line-height:1.1;text-shadow:0 0 8px rgba(184,212,0,0.6);">DTS Dépannage</div>
          <div style="color:#4a7a5a;font-size:0.72rem;line-height:1;">Elec · 24h/24</div>
        </div>
      </a>
      <div style="display:none;gap:1.5rem;align-items:center;" class="nav-links">
        <a href="/depannage-electricite/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Dépannage</a>
        <a href="/tarifs/" style="color:#b8d400;text-decoration:none;font-size:0.88rem;font-weight:600;">Tarifs</a>
        <a href="/zones/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Zones</a>
        <a href="/contact/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Contact</a>
      </div>
      <a href={PHONE_TEL} class="btn-cta" style="padding:0.6rem 1rem;font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="nav-phone-hide">Appeler — </span>{PHONE_DISPLAY}
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section style="padding:3.5rem 1.25rem 4rem;background:linear-gradient(160deg,#060d16 0%,#071408 60%,#060d16 100%);text-align:center;">
    <div style="max-width:800px;margin:0 auto;">
      <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.75rem;">ZÉRO SURPRISE</p>
      <h1 style="font-size:clamp(1.75rem,5vw,2.8rem);font-weight:900;line-height:1.15;margin:0 0 1.25rem;color:#f0f8f0;">
        Tarifs Dépannage Électrique —<br>
        <span class="neon-green">Transparents et Affichés</span>
      </h1>
      <p style="font-size:1.05rem;color:#8ab89a;margin:0 0 2rem;line-height:1.7;max-width:600px;margin-left:auto;margin-right:auto;">
        Chez DTS Dépannage Elec, chaque tarif est communiqué avant l'intervention.
        Vous savez exactement ce que vous allez payer avant notre arrivée.
        <strong style="color:#c8e0c8;">Devis signé avant tous travaux. Zéro surprise.</strong>
      </p>
      <a href={PHONE_TEL} class="btn-cta" style="font-size:1.1rem;padding:1.1rem 2rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="cta-prefix">Appelez maintenant</span><span class="phone-nowrap">{PHONE_DISPLAY}</span>
      </a>
    </div>
  </section>

  <!-- TABLEAUX TARIFS -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;margin-bottom:2rem;">

        <!-- Journée -->
        <div class="card" style="overflow:hidden;">
          <div style="background:rgba(184,212,0,0.08);padding:1.25rem 1.5rem;border-bottom:1px solid rgba(184,212,0,0.15);display:flex;align-items:center;gap:0.75rem;">
            <span style="font-size:1.8rem;">☀️</span>
            <div>
              <div style="color:#b8d400;font-weight:800;font-size:1.2rem;text-shadow:0 0 8px rgba(184,212,0,0.6);">Journée</div>
              <div style="color:#4a7a5a;font-size:0.85rem;">7h → 19h — du lundi au dimanche</div>
            </div>
          </div>
          <table class="tarif-table">
            <thead>
              <tr>
                <th>Prestation</th>
                <th style="text-align:right;">Prix HT</th>
              </tr>
            </thead>
            <tbody>
              {tarifsJournee.map(t => (
                <tr>
                  <td>{t.prestation}</td>
                  <td>{t.prix}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Nuit -->
        <div class="card" style="overflow:hidden;">
          <div style="background:rgba(74,179,255,0.06);padding:1.25rem 1.5rem;border-bottom:1px solid rgba(74,179,255,0.15);display:flex;align-items:center;gap:0.75rem;">
            <span style="font-size:1.8rem;">🌙</span>
            <div>
              <div style="color:#4ab3ff;font-weight:800;font-size:1.2rem;text-shadow:0 0 8px rgba(74,179,255,0.6);">Nuit</div>
              <div style="color:#4a7a5a;font-size:0.85rem;">19h → 7h — du lundi au dimanche</div>
            </div>
          </div>
          <table class="tarif-table">
            <thead>
              <tr>
                <th style="color:#4ab3ff;">Prestation</th>
                <th style="text-align:right;color:#4ab3ff;">Prix HT</th>
              </tr>
            </thead>
            <tbody>
              {tarifsNuit.map(t => (
                <tr>
                  <td>{t.prestation}</td>
                  <td style="color:#4ab3ff;text-shadow:0 0 6px rgba(74,179,255,0.5);">{t.prix}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

      </div>

      <!-- Notes tarifaires -->
      <div style="background:rgba(184,212,0,0.04);border:1px solid rgba(184,212,0,0.15);border-radius:0.875rem;padding:1.5rem;">
        <h3 style="color:#b8d400;font-size:1rem;font-weight:700;margin:0 0 1rem;text-shadow:0 0 6px rgba(184,212,0,0.4);">Informations tarifaires importantes</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem;">
          <li style="display:flex;align-items:flex-start;gap:0.5rem;color:#8ab89a;font-size:0.9rem;line-height:1.5;">
            <span style="color:#b8d400;flex-shrink:0;">→</span>
            Au-delà d'1 heure d'intervention, la main d'œuvre supplémentaire est facturée à l'heure selon le tarif en vigueur.
          </li>
          <li style="display:flex;align-items:flex-start;gap:0.5rem;color:#8ab89a;font-size:0.9rem;line-height:1.5;">
            <span style="color:#b8d400;flex-shrink:0;">→</span>
            Un devis est systématiquement signé avant le début de tout travail. Vous n'êtes engagé qu'après votre accord écrit.
          </li>
          <li style="display:flex;align-items:flex-start;gap:0.5rem;color:#8ab89a;font-size:0.9rem;line-height:1.5;">
            <span style="color:#b8d400;flex-shrink:0;">→</span>
            Tous les prix sont indiqués <strong style="color:#c8e0c8;">hors taxes (HT)</strong>. La TVA en vigueur s'applique sur la facture finale.
          </li>
          <li style="display:flex;align-items:flex-start;gap:0.5rem;color:#8ab89a;font-size:0.9rem;line-height:1.5;">
            <span style="color:#b8d400;flex-shrink:0;">→</span>
            Paiement accepté par <strong style="color:#c8e0c8;">carte bancaire</strong> (TPE) ou <strong style="color:#c8e0c8;">espèces</strong> sur place, directement après l'intervention.
          </li>
        </ul>
      </div>

    </div>
  </section>

  <!-- CE QUI EST INCLUS -->
  <section style="padding:4rem 1.25rem;background:linear-gradient(180deg,#060d16 0%,#040c0a 100%);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <h2 class="section-title">Ce qui est inclus dans le tarif</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">
        {[
          { icon: "🚗", title: "Déplacement inclus", desc: "Le tarif de déplacement couvre le trajet aller-retour jusqu'à votre domicile ou local, quel que soit l'endroit dans notre zone." },
          { icon: "🔍", title: "Diagnostic sur place", desc: "Notre technicien réalise un diagnostic complet de votre installation pour identifier précisément l'origine du problème." },
          { icon: "🔧", title: "Intervention immédiate", desc: "Si la réparation est possible immédiatement, nous l'effectuons sur place dans le même délai, avec le matériel embarqué." },
          { icon: "📝", title: "Rapport d'intervention", desc: "À l'issue de chaque intervention, un compte-rendu vous est remis décrivant le problème constaté et les travaux réalisés." },
        ].map(e => (
          <div class="card" style="padding:1.5rem;">
            <div style="font-size:2rem;margin-bottom:0.75rem;">{e.icon}</div>
            <h3 style="color:#b8d400;font-weight:700;font-size:1rem;margin:0 0 0.5rem;">{e.title}</h3>
            <p style="color:#6a9a7a;font-size:0.88rem;margin:0;line-height:1.6;">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NOS ENGAGEMENTS TARIFAIRES -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;">NOTRE PROMESSE</p>
        <h2 class="section-title">Nos engagements tarifaires</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">
        {[
          { num: "01", title: "Prix HT affichés", desc: "Nos tarifs HT sont publics et communiqués avant toute intervention. Pas de tarif caché, pas de majoration non annoncée." },
          { num: "02", title: "Devis signé", desc: "Pour tout travail dépassant le simple déplacement et diagnostic, un devis signé est obligatoire avant le début de l'intervention." },
          { num: "03", title: "Pas de frais cachés", desc: "Le tarif annoncé est le tarif facturé. Aucun frais de dossier, aucune majoration de fin d'intervention, aucune surprise." },
          { num: "04", title: "CB + Espèces acceptés", desc: "Règlement par carte bancaire via TPE, ou en espèces directement sur place après l'intervention." },
        ].map(e => (
          <div class="card" style="padding:1.5rem;">
            <div style="color:#b8d400;font-size:2rem;font-weight:900;margin-bottom:0.5rem;text-shadow:0 0 12px rgba(184,212,0,0.4);line-height:1;">{e.num}</div>
            <h3 style="color:#f0f8f0;font-weight:700;font-size:1rem;margin:0 0 0.5rem;">{e.title}</h3>
            <p style="color:#6a9a7a;font-size:0.88rem;margin:0;line-height:1.6;">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section style="padding:4rem 1.25rem;background:linear-gradient(135deg,#1a2e00 0%,#0f2400 50%,#0a1e00 100%);border-top:1px solid rgba(184,212,0,0.2);border-bottom:1px solid rgba(184,212,0,0.2);">
    <div style="max-width:700px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:1.25rem;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;font-size:0.9rem;">Disponible maintenant — Réponse immédiate</span>
      </div>
      <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#f0f8f0;margin:0 0 0.75rem;line-height:1.2;">
        Une urgence électrique ?
      </h2>
      <p style="color:#8ab89a;font-size:1.05rem;margin:0 0 2rem;line-height:1.6;">
        Appelez-nous — tarif communiqué dès le 1er appel, devis signé avant toute intervention.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.2rem;padding:1.1rem 2.25rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {PHONE_DISPLAY}
        </a>
      </div>
    </div>
  </section>

  <!-- BOUTON FLOTTANT MOBILE -->
  <div class="floating-cta" role="complementary" aria-label="Appel rapide">
    <a href={PHONE_TEL} class="tel">📞 {PHONE_DISPLAY}</a>
  </div>

  <!-- FOOTER -->
  <footer style="background:#030a0f;border-top:1px solid rgba(184,212,0,0.1);padding:3rem 1.25rem 2rem;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;margin-bottom:2rem;">
        <div>
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.875rem;">
            <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
              <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="48" height="38" style="width:48px;height:38px;object-fit:contain;display:block;transform:translateY(-2px);" />
            </div>
            <div>
              <div style="color:#b8d400;font-weight:800;font-size:0.9rem;text-shadow:0 0 6px rgba(184,212,0,0.5);">DTS Dépannage Elec</div>
              <div style="color:#4a7a5a;font-size:0.7rem;">Urgence 24h/24 — 7j/7</div>
            </div>
          </div>
          <p style="color:#4a7a5a;font-size:0.82rem;line-height:1.6;margin:0;">Électricien urgence sur la zone franco-suisse. Tarif affiché, devis avant travaux.</p>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Interventions</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
            {["Panne générale", "Disjoncteur sauté", "Tableau électrique", "Prises & éclairage", "Mise en sécurité", "Urgence pro"].map(s => (
              <li style="color:#4a7a5a;font-size:0.82rem;">{s}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Zones</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
            {["Pays de Gex (01)", "Annemasse +40 km", "Thonon +20 km", "Annecy +40 km", "Bellegarde +20 km"].map(z => (
              <li style="color:#4a7a5a;font-size:0.82rem;">{z}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Contact</h3>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <a href={PHONE_TEL} style="color:#c8e0c8;font-size:0.88rem;text-decoration:none;display:flex;align-items:center;gap:0.4rem;">📞 <span>{PHONE_DISPLAY}</span></a>
            <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.25rem;">
              <span class="pulse-dot" style="width:7px;height:7px;"></span>
              <span style="color:#b8d400;font-size:0.82rem;font-weight:600;">Disponible maintenant</span>
            </div>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid rgba(184,212,0,0.08);padding-top:1.25rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:space-between;align-items:center;">
        <p style="color:#2a4a3a;font-size:0.75rem;margin:0;">© 2025 DTS Dépannage Elec — Déco Travaux Services. Entreprise française.</p>
        <div style="display:flex;gap:1rem;">
          <a href="/tarifs/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Tarifs</a>
          <a href="/zones/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Zones</a>
          <a href="/contact/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Contact</a>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .nav-phone-hide { display: none; }
  @media (min-width: 700px) {
    .nav-links { display: flex !important; }
  }
  @media (min-width: 900px) {
    .nav-phone-hide { display: inline !important; }
  }
</style>
