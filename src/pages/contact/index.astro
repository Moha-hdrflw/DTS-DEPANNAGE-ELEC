---
import Layout from '../../layouts/Layout.astro';

const PHONE_DISPLAY = "06 XX XX XX XX";
const PHONE_TEL     = "tel:+3306XXXXXXXX";
const WHATSAPP_URL  = "https://wa.me/336XXXXXXXX";
---

<Layout
  title="Contact Électricien Urgence — DTS Dépannage Elec | Appel Direct 24h/24"
  description="Contactez DTS Dépannage Elec pour toute urgence électrique 24h/24 7j/7. Appelez directement ou envoyez un message WhatsApp. Réponse immédiate."
>

  <!-- BARRE URGENCE -->
  <div style="position:sticky;top:0;z-index:50;background:rgba(6,13,22,0.97);border-bottom:1px solid rgba(184,212,0,0.25);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.55rem 1rem;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0.5rem 1.25rem;text-align:center;">
      <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:#c8e0c8;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;">Disponible 24h/24 — 7j/7</span>
      </span>
      <span style="font-size:0.8rem;color:#c8e0c8;">⚡ Intervention rapide</span>
      <span style="font-size:0.8rem;color:#c8e0c8;">Pays de Gex · Annemasse · Annecy · Thonon</span>
      <a href={PHONE_TEL} style="background:#b8d400;color:#060d16;font-weight:800;padding:0.3rem 0.85rem;border-radius:0.4rem;font-size:0.82rem;text-decoration:none;white-space:nowrap;box-shadow:0 0 12px rgba(184,212,0,0.45);">
        📞 {PHONE_DISPLAY}
      </a>
    </div>
  </div>

  <!-- NAVIGATION -->
  <nav style="background:rgba(6,13,22,0.95);border-bottom:1px solid rgba(184,212,0,0.08);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="54" height="42" style="width:54px;height:42px;object-fit:contain;display:block;transform:translateY(-2px);" />
        </div>
        <div>
          <div style="color:#b8d400;font-weight:800;font-size:0.95rem;line-height:1.1;text-shadow:0 0 8px rgba(184,212,0,0.6);">DTS Dépannage</div>
          <div style="color:#4a7a5a;font-size:0.72rem;line-height:1;">Elec · 24h/24</div>
        </div>
      </a>
      <div style="display:none;gap:1.5rem;align-items:center;" class="nav-links">
        <a href="/depannage-electricite/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Dépannage</a>
        <a href="/tarifs/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Tarifs</a>
        <a href="/zones/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Zones</a>
        <a href="/contact/" style="color:#b8d400;text-decoration:none;font-size:0.88rem;font-weight:600;">Contact</a>
      </div>
      <a href={PHONE_TEL} class="btn-cta" style="padding:0.6rem 1rem;font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="nav-phone-hide">Appeler — </span>{PHONE_DISPLAY}
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section style="padding:3.5rem 1.25rem 4rem;background:linear-gradient(160deg,#060d16 0%,#071408 60%,#060d16 100%);text-align:center;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(184,212,0,0.08);border:1px solid rgba(184,212,0,0.3);border-radius:2rem;padding:0.45rem 1rem;margin-bottom:1.5rem;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;font-size:0.88rem;">Disponible maintenant — Réponse immédiate</span>
      </div>
      <h1 style="font-size:clamp(1.75rem,5vw,2.8rem);font-weight:900;line-height:1.15;margin:0 0 1.25rem;color:#f0f8f0;">
        Contactez-Nous —<br>
        <span class="neon-green">Urgence Électrique 24h/24</span>
      </h1>
      <p style="font-size:1.05rem;color:#8ab89a;margin:0 0 2.5rem;line-height:1.7;">
        Pas de formulaire. Pas d'email. <strong style="color:#c8e0c8;">Contact direct uniquement.</strong><br>
        Pour toute urgence électrique, appelez-nous ou envoyez un WhatsApp — réponse immédiate.
      </p>

      <!-- Boutons contact -->
      <div style="display:flex;flex-direction:column;gap:1rem;align-items:center;max-width:400px;margin:0 auto 2rem;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.3rem;padding:1.3rem 2.5rem;width:100%;justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Appeler — {PHONE_DISPLAY}
        </a>
        <a href={WHATSAPP_URL} class="btn-whatsapp" style="font-size:1.15rem;padding:1.2rem 2.25rem;width:100%;justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.104 1.524 5.828L.057 23.5l5.83-1.449A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.848 0-3.574-.504-5.055-1.383l-.363-.215-3.754.932.975-3.651-.236-.376A9.948 9.948 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Message WhatsApp
        </a>
      </div>

      <!-- Horaires badge -->
      <div style="display:inline-flex;align-items:center;gap:0.75rem;background:rgba(184,212,0,0.06);border:1px solid rgba(184,212,0,0.2);border-radius:0.75rem;padding:0.75rem 1.25rem;">
        <span style="font-size:1.5rem;">🕐</span>
        <div style="text-align:left;">
          <div style="color:#b8d400;font-weight:700;font-size:0.9rem;">24h/24 — 7j/7</div>
          <div style="color:#4a7a5a;font-size:0.78rem;">Jours fériés inclus</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMENT CA MARCHE -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;">SIMPLE ET RAPIDE</p>
        <h2 class="section-title">Comment ça marche ?</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;">
        {[
          {
            step: "01",
            title: "Vous appelez",
            desc: "Vous nous contactez par téléphone ou WhatsApp. Réponse immédiate — nous écoutons votre situation et évaluons l'urgence.",
            icon: "📞"
          },
          {
            step: "02",
            title: "On évalue",
            desc: "Nous vous communiquons le tarif applicable et, si nécessaire, nous vous guidons par téléphone pour les vérifications de base avant notre arrivée.",
            icon: "🔍"
          },
          {
            step: "03",
            title: "On intervient",
            desc: "Notre technicien se déplace, réalise le diagnostic, présente un devis signé, puis procède à l'intervention. Paiement sur place après l'intervention.",
            icon: "⚡"
          },
        ].map(e => (
          <div class="card" style="padding:1.75rem;text-align:center;">
            <div style="font-size:2.5rem;margin-bottom:0.5rem;">{e.icon}</div>
            <div style="color:#b8d400;font-size:2rem;font-weight:900;margin-bottom:0.5rem;text-shadow:0 0 12px rgba(184,212,0,0.4);">{e.step}</div>
            <h3 style="color:#f0f8f0;font-weight:700;font-size:1.1rem;margin:0 0 0.75rem;">{e.title}</h3>
            <p style="color:#6a9a7a;font-size:0.88rem;margin:0;line-height:1.6;">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONES + INFOS -->
  <section style="padding:4rem 1.25rem;background:linear-gradient(180deg,#060d16 0%,#040c0a 100%);">
    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;">

      <!-- Zones -->
      <div class="card" style="padding:1.75rem;">
        <h2 style="color:#4ab3ff;font-size:1.15rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(74,179,255,0.5);">Zones desservies</h2>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem;">
          {[
            "Pays de Gex — Gex, Ferney-Voltaire, Saint-Genis-Pouilly, Thoiry, Divonne",
            "Annemasse +40 km — Saint-Julien, Cranves-Sales, Ville-la-Grand",
            "Thonon-les-Bains +20 km — Douvaine, Sciez, Évian",
            "Annecy +40 km — Cran-Gevrier, Seynod, Meythet",
            "Bellegarde-sur-Valserine +20 km",
          ].map(z => (
            <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.85rem;color:#8ab89a;line-height:1.4;">
              <span style="width:6px;height:6px;background:#b8d400;border-radius:50%;flex-shrink:0;margin-top:0.35rem;box-shadow:0 0 4px rgba(184,212,0,0.7);"></span>
              {z}
            </li>
          ))}
        </ul>
        <p style="color:#4a7a5a;font-size:0.8rem;margin:1rem 0 0;padding-top:0.75rem;border-top:1px solid rgba(184,212,0,0.1);">
          Entreprise française — pas d'intervention en Suisse.
        </p>
      </div>

      <!-- FAQ rapide -->
      <div class="card" style="padding:1.75rem;">
        <h2 style="color:#4ab3ff;font-size:1.15rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(74,179,255,0.5);">Questions fréquentes</h2>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {[
            {
              q: "Réponse en combien de temps ?",
              a: "Réponse téléphonique immédiate. Nous ne promettons pas un délai d'arrivée précis, mais organisons l'intervention le plus rapidement possible."
            },
            {
              q: "Ma ville est-elle couverte ?",
              a: "Si vous êtes dans le Pays de Gex, aux alentours d'Annemasse, Thonon, Annecy ou Bellegarde, appelez-nous — nous couvrons toute la zone frontalière côté français."
            },
            {
              q: "Puis-je envoyer un message plutôt qu'appeler ?",
              a: "Oui, WhatsApp est disponible. Pour les urgences, l'appel direct reste la meilleure option pour une réponse immédiate."
            },
            {
              q: "Acceptez-vous les urgences professionnelles ?",
              a: "Oui. Hôtels, restaurants, copropriétés — nous traitons les urgences professionnelles avec la même priorité."
            },
          ].map(f => (
            <div>
              <h3 style="color:#b8d400;font-size:0.88rem;font-weight:700;margin:0 0 0.35rem;">{f.q}</h3>
              <p style="color:#6a9a7a;font-size:0.85rem;margin:0;line-height:1.55;">{f.a}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- CTA FINAL -->
  <section style="padding:4rem 1.25rem;background:linear-gradient(135deg,#1a2e00 0%,#0f2400 50%,#0a1e00 100%);border-top:1px solid rgba(184,212,0,0.2);border-bottom:1px solid rgba(184,212,0,0.2);">
    <div style="max-width:700px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:1.25rem;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;font-size:0.9rem;">Disponible maintenant — Réponse immédiate</span>
      </div>
      <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#f0f8f0;margin:0 0 0.75rem;">Appelez maintenant</h2>
      <p style="color:#8ab89a;font-size:1.05rem;margin:0 0 2rem;line-height:1.6;">
        Tarif communiqué dès le 1er appel — devis signé avant toute intervention.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.2rem;padding:1.1rem 2.25rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {PHONE_DISPLAY}
        </a>
        <a href={WHATSAPP_URL} class="btn-whatsapp" style="font-size:1.1rem;padding:1.1rem 2rem;">
          💬 WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- BOUTON FLOTTANT MOBILE -->
  <div class="floating-cta" role="complementary" aria-label="Appel rapide">
    <a href={PHONE_TEL} class="tel">📞 {PHONE_DISPLAY}</a>
    <a href={WHATSAPP_URL} class="wa">💬 WhatsApp</a>
  </div>

  <!-- FOOTER -->
  <footer style="background:#030a0f;border-top:1px solid rgba(184,212,0,0.1);padding:3rem 1.25rem 2rem;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;margin-bottom:2rem;">
        <div>
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.875rem;">
            <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
              <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="48" height="38" style="width:48px;height:38px;object-fit:contain;display:block;transform:translateY(-2px);" />
            </div>
            <div>
              <div style="color:#b8d400;font-weight:800;font-size:0.9rem;text-shadow:0 0 6px rgba(184,212,0,0.5);">DTS Dépannage Elec</div>
              <div style="color:#4a7a5a;font-size:0.7rem;">Urgence 24h/24 — 7j/7</div>
            </div>
          </div>
          <p style="color:#4a7a5a;font-size:0.82rem;line-height:1.6;margin:0;">Électricien urgence sur la zone franco-suisse. Tarif affiché, devis avant travaux.</p>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Interventions</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
            {["Panne générale", "Disjoncteur sauté", "Tableau électrique", "Prises & éclairage", "Mise en sécurité", "Urgence pro"].map(s => (
              <li style="color:#4a7a5a;font-size:0.82rem;">{s}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Zones</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
            {["Pays de Gex (01)", "Annemasse +40 km", "Thonon +20 km", "Annecy +40 km", "Bellegarde +20 km"].map(z => (
              <li style="color:#4a7a5a;font-size:0.82rem;">{z}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Contact</h3>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <a href={PHONE_TEL} style="color:#c8e0c8;font-size:0.88rem;text-decoration:none;display:flex;align-items:center;gap:0.4rem;">📞 <span>{PHONE_DISPLAY}</span></a>
            <a href={WHATSAPP_URL} style="color:#c8e0c8;font-size:0.88rem;text-decoration:none;display:flex;align-items:center;gap:0.4rem;">💬 <span>WhatsApp</span></a>
            <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.25rem;">
              <span class="pulse-dot" style="width:7px;height:7px;"></span>
              <span style="color:#b8d400;font-size:0.82rem;font-weight:600;">Disponible maintenant</span>
            </div>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid rgba(184,212,0,0.08);padding-top:1.25rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:space-between;align-items:center;">
        <p style="color:#2a4a3a;font-size:0.75rem;margin:0;">© 2025 DTS Dépannage Elec — Déco Travaux Services. Entreprise française.</p>
        <div style="display:flex;gap:1rem;">
          <a href="/tarifs/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Tarifs</a>
          <a href="/zones/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Zones</a>
          <a href="/contact/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Contact</a>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .nav-phone-hide { display: none; }
  @media (min-width: 700px) {
    .nav-links { display: flex !important; }
  }
  @media (min-width: 900px) {
    .nav-phone-hide { display: inline !important; }
  }
</style>
