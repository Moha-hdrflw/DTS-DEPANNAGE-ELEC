---
import Layout from '../../layouts/Layout.astro';

const PHONE_DISPLAY = "06 XX XX XX XX";
const PHONE_TEL     = "tel:+3306XXXXXXXX";
const WHATSAPP_URL  = "https://wa.me/336XXXXXXXX";

const tarifsJournee = [
  { prestation: "Déplacement",                prix: "75 € HT" },
  { prestation: "Recherche de panne",          prix: "195 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "90 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "130 € HT" },
];

const tarifsNuit = [
  { prestation: "Déplacement",                prix: "115 € HT" },
  { prestation: "Recherche de panne",          prix: "230 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "150 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "145 € HT" },
];

const faq = [
  {
    q: "Intervenez-vous la nuit et le week-end ?",
    a: "Oui, DTS Dépannage Elec est disponible 24h/24, 7j/7, y compris les nuits, les week-ends et les jours fériés. Notre tarif nuit s'applique de 19h à 7h, tous les jours de l'année. Dès votre appel, nous évaluons votre situation et organisons l'intervention sans délai inutile."
  },
  {
    q: "Quel est le délai d'intervention ?",
    a: "Nous intervenons le plus rapidement possible après votre appel. Le délai dépend de notre disponibilité et de votre localisation sur la zone couverte — Pays de Gex, Annemasse, Thonon-les-Bains, Annecy ou Bellegarde. Nous ne promettons pas de délai précis, mais la réponse téléphonique est immédiate."
  },
  {
    q: "Comment sont calculés vos tarifs ?",
    a: "Nos tarifs sont fixes et communiqués avant toute intervention. Ils comprennent : le déplacement, la recherche de panne ou la main d'œuvre à l'heure, et la mise en sécurité si nécessaire. Tous les prix sont en HT. La TVA en vigueur s'applique. Au-delà d'1h d'intervention, la main d'œuvre supplémentaire est facturée à l'heure."
  },
  {
    q: "Faites-vous un devis avant d'intervenir ?",
    a: "Oui, systématiquement. Un devis signé est établi avant toute intervention ou travaux. Vous connaissez le coût exact avant que nous commencions. Aucune surprise sur la facture finale. C'est notre engagement de transparence tarifaire."
  },
  {
    q: "Acceptez-vous la carte bancaire ?",
    a: "Oui, nous acceptons le paiement par carte bancaire (via TPE) ainsi que les espèces sur place. Vous pouvez régler directement après l'intervention, sans avoir à vous déplacer ni à faire de virement."
  },
  {
    q: "Intervenez-vous en Suisse ?",
    a: "Non. DTS Dépannage Elec est une entreprise française et n'intervient pas en Suisse. Nous couvrons uniquement la zone française : Pays de Gex (01), Annemasse et ses alentours (74), Thonon-les-Bains (74), Annecy (74) et Bellegarde-sur-Valserine (01). La proximité de Genève est un atout pour nos clients frontaliers côté français."
  },
  {
    q: "Que faire en cas de panne totale ?",
    a: "Avant d'appeler, vérifiez si vos voisins sont également touchés — il peut s'agir d'une panne réseau EDF. Si vous êtes seul concerné, vérifiez votre tableau électrique : regardez si le disjoncteur principal ou un différentiel a sauté. Ne touchez à rien si vous ne savez pas ce que vous faites, et appelez-nous immédiatement. Nous guidons par téléphone si possible, et intervenons sur place si nécessaire."
  },
  {
    q: "Quelle zone couvrez-vous exactement ?",
    a: "Nous couvrons : tout le Pays de Gex (01), Annemasse et un rayon de 40 km (74), Thonon-les-Bains et un rayon de 20 km (74), Annecy et un rayon de 40 km (74), Bellegarde-sur-Valserine et un rayon de 20 km (01). Si vous n'êtes pas sûr d'être dans notre zone, appelez-nous — nous ferons notre possible."
  },
];
---

<Layout
  title="Dépannage Électricité Urgence Pays de Gex Annemasse — DTS | 24h/24"
  description="Dépannage électricité urgence 24h/24 7j/7 sur le Pays de Gex, Annemasse, Thonon et Annecy. Panne, disjoncteur, tableau électrique — DTS Dépannage Elec intervient rapidement."
>

  <!-- BARRE URGENCE -->
  <div style="position:sticky;top:0;z-index:50;background:rgba(6,13,22,0.97);border-bottom:1px solid rgba(184,212,0,0.25);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.55rem 1rem;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0.5rem 1.25rem;text-align:center;">
      <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:#c8e0c8;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;">Disponible 24h/24 — 7j/7</span>
      </span>
      <span style="font-size:0.8rem;color:#c8e0c8;">⚡ Intervention rapide</span>
      <span style="font-size:0.8rem;color:#c8e0c8;">Pays de Gex · Annemasse · Annecy · Thonon</span>
      <a href={PHONE_TEL} style="background:#b8d400;color:#060d16;font-weight:800;padding:0.3rem 0.85rem;border-radius:0.4rem;font-size:0.82rem;text-decoration:none;white-space:nowrap;box-shadow:0 0 12px rgba(184,212,0,0.45);">
        📞 {PHONE_DISPLAY}
      </a>
    </div>
  </div>

  <!-- NAVIGATION -->
  <nav style="background:rgba(6,13,22,0.95);border-bottom:1px solid rgba(184,212,0,0.08);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="54" height="42" style="width:54px;height:42px;object-fit:contain;display:block;transform:translateY(-2px);" />
        </div>
        <div>
          <div style="color:#b8d400;font-weight:800;font-size:0.95rem;line-height:1.1;text-shadow:0 0 8px rgba(184,212,0,0.6);">DTS Dépannage</div>
          <div style="color:#4a7a5a;font-size:0.72rem;line-height:1;">Elec · 24h/24</div>
        </div>
      </a>
      <div style="display:none;gap:1.5rem;align-items:center;" class="nav-links">
        <a href="/depannage-electricite/" style="color:#b8d400;text-decoration:none;font-size:0.88rem;font-weight:600;">Dépannage</a>
        <a href="/tarifs/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Tarifs</a>
        <a href="/zones/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Zones</a>
        <a href="/contact/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Contact</a>
      </div>
      <a href={PHONE_TEL} class="btn-cta" style="padding:0.6rem 1rem;font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="nav-phone-hide">Appeler — </span>{PHONE_DISPLAY}
      </a>
    </div>
  </nav>

  <!-- HERO / INTRO -->
  <section style="position:relative;overflow:hidden;padding:3.5rem 1.25rem 4rem;background:linear-gradient(160deg,#060d16 0%,#071408 60%,#060d16 100%);">
    <svg style="position:absolute;top:8%;left:6%;opacity:0.05;pointer-events:none;" width="60" height="100" viewBox="0 0 60 100" fill="#b8d400"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <svg style="position:absolute;top:15%;right:8%;opacity:0.04;pointer-events:none;" width="44" height="74" viewBox="0 0 60 100" fill="#4ab3ff"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(184,212,0,0.08);border:1px solid rgba(184,212,0,0.3);border-radius:2rem;padding:0.45rem 1rem;margin-bottom:1.5rem;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;font-size:0.88rem;">Disponible maintenant — Réponse immédiate</span>
      </div>
      <h1 style="font-size:clamp(1.75rem,5vw,2.8rem);font-weight:900;line-height:1.15;margin:0 0 1.25rem;color:#f0f8f0;">
        Dépannage Électricité Urgence —<br>
        <span class="neon-green">Pays de Gex, Annemasse, Thonon, Annecy</span>
      </h1>
      <p style="font-size:1.05rem;color:#8ab89a;margin:0 0 2rem;line-height:1.7;max-width:700px;margin-left:auto;margin-right:auto;">
        DTS Dépannage Elec est votre électricien urgence 24h/24, 7j/7, sur toute la zone frontalière franco-suisse.
        Panne générale, disjoncteur sauté, tableau électrique défaillant, mise en sécurité — nous intervenons rapidement,
        avec un tarif affiché dès le premier appel et un devis signé avant tous travaux.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.1rem;padding:1.1rem 2rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Appelez maintenant — {PHONE_DISPLAY}
        </a>
        <a href={WHATSAPP_URL} class="btn-whatsapp" style="font-size:1rem;padding:1.1rem 1.75rem;">
          💬 WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- NOS INTERVENTIONS D'URGENCE -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;">DÉPANNAGE UNIQUEMENT</p>
        <h2 class="section-title">Nos interventions d'urgence</h2>
        <p style="color:#6a9a7a;font-size:0.95rem;max-width:560px;margin:0.5rem auto 0;">
          Tous types de pannes électriques résolus par nos techniciens qualifiés — logements, locaux professionnels, copropriétés.
        </p>
      </div>

      <!-- 1. Panne générale -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          ⚡ 1. Panne générale / Coupure totale
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Une coupure totale de courant est une urgence qui peut paralyser un logement ou un local professionnel en quelques secondes.
          Lorsque plus aucun circuit ne fonctionne — pas d'éclairage, pas de prises, pas d'équipements — le problème peut provenir
          du disjoncteur principal, d'un défaut d'isolement sur l'installation, ou d'un problème sur le réseau ENEDIS.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Notre technicien commence par un diagnostic complet de l'installation pour identifier l'origine exacte de la panne.
          Il vérifie le tableau général, les disjoncteurs divisionnaires, les protections différentielles et l'état du câblage.
          Si la panne provient d'un défaut sur votre installation, nous procédons immédiatement à la réparation ou à la mise en sécurité.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Intervention disponible jour et nuit, 7j/7. Tarif de déplacement : 75 € HT (journée) ou 115 € HT (nuit), auquel
          s'ajoute la recherche de panne et/ou la main d'œuvre selon l'intervention.
        </p>
      </div>

      <!-- 2. Disjoncteur sauté -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          🔌 2. Disjoncteur sauté (différentiel, sectionneur)
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Un disjoncteur qui saute régulièrement ou qui ne se remet pas en position est le signe d'un problème électrique
          sous-jacent qui ne doit pas être ignoré. Il peut s'agir d'un court-circuit, d'une surcharge, d'un défaut d'isolement,
          ou d'un appareil électrique défaillant connecté au circuit.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Nous diagnostiquons le circuit concerné, identifions la cause du déclenchement et procédons à la réparation.
          Selon le cas, nous pouvons remplacer le disjoncteur défaillant, réparer une connexion défectueuse, isoler l'appareil
          en cause ou revoir le calibrage des protections.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Ne forcez jamais un disjoncteur qui refuse de rester enclenché : c'est un signal de danger. Appelez-nous avant
          que la situation ne s'aggrave.
        </p>
      </div>

      <!-- 3. Tableau électrique -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          🗄️ 3. Tableau électrique (remplacement, mise aux normes)
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Le tableau électrique est le cœur de votre installation. Un tableau vétuste, mal dimensionné ou non conforme
          aux normes NF C 15-100 représente un risque sérieux d'incendie ou d'électrocution. Les tableaux anciens
          (fusibles à cartouche, disjoncteurs dépassés) ne protègent plus efficacement votre installation.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Nous réalisons le remplacement complet du tableau électrique, l'ajout de protections (différentiels 30 mA,
          disjoncteurs divisionnaires), la mise aux normes des circuits existants et le repérage des lignes.
          Chaque intervention est accompagnée d'un devis signé avant le début des travaux.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Mise en sécurité électrique à partir de 130 € HT (journée). Un tableau conforme, c'est votre sécurité
          et celle de votre famille.
        </p>
      </div>

      <!-- 4. Prises et éclairage -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          💡 4. Prises et éclairage (court-circuit, prise HS)
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Une prise qui ne fonctionne plus, un interrupteur qui grésille, un éclairage qui clignote ou des odeurs de brûlé
          autour d'une prise sont des signaux d'alarme électrique. Ces problèmes en apparence anodins peuvent cacher
          un court-circuit, un contact desserré ou un début d'arc électrique susceptible de provoquer un incendie.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Notre technicien intervient pour remplacer les prises défaillantes, réparer les connexions, diagnostiquer
          les circuits d'éclairage en défaut et vérifier l'état général du câblage dans les zones concernées.
          Tous les travaux de remplacement sont effectués avec du matériel conforme aux normes en vigueur.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Ne laissez pas une prise ou un interrupteur défaillant sans intervention : les conséquences peuvent être graves.
          Appelez-nous pour un diagnostic rapide, déplacement à partir de 75 € HT.
        </p>
      </div>

      <!-- 5. Mise en sécurité -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          🛡️ 5. Mise en sécurité électrique (risque incendie, électrocution)
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Une installation électrique vieillissante, des câbles dénudés, une absence de mise à la terre, des connexions
          oxydées ou un câblage non conforme constituent autant de risques majeurs pour la sécurité des personnes et
          des biens. La mise en sécurité est une intervention prioritaire que nous traitons en urgence absolue.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Notre technicien évalue l'ensemble de l'installation, identifie les zones dangereuses et procède à la
          neutralisation des circuits à risque, au remplacement des éléments défectueux et à la mise en conformité
          des points critiques. Un rapport d'intervention vous est remis à l'issue.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Mise en sécurité électrique : 130 € HT (journée), 145 € HT (nuit). N'attendez pas une catastrophe
          pour faire vérifier votre installation.
        </p>
      </div>

      <!-- 6. Urgence pro -->
      <div class="card" style="padding:2rem;margin-bottom:1.25rem;">
        <h3 style="color:#b8d400;font-size:1.2rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(184,212,0,0.5);">
          🏢 6. Urgence professionnelle (hôtels, restaurants, copropriétés)
        </h3>
        <p style="color:#c8e0c8;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          Pour les professionnels, une panne électrique signifie une activité paralysée, des clients insatisfaits
          et des pertes financières immédiates. Hôtels sans courant dans les chambres, restaurants avec chambres
          froides HS, copropriétés sans éclairage commun ou sans ascenseur — ces situations exigent une réponse rapide.
        </p>
        <p style="color:#8ab89a;font-size:0.95rem;line-height:1.75;margin:0 0 0.75rem;">
          DTS Dépannage Elec traite les urgences professionnelles avec la même priorité que les urgences résidentielles.
          Nous intervenons sur les tableaux divisionnaires, les circuits trifasés, les systèmes d'éclairage de sécurité,
          les alimentations des équipements frigorifiques et les systèmes de ventilation.
        </p>
        <p style="color:#6a9a7a;font-size:0.9rem;line-height:1.6;margin:0;">
          Disponible 24h/24 pour vos urgences professionnelles. Réponse immédiate, intervention organisée sans délai
          inutile. Tarif professionnel identique aux tarifs affichés — zéro surprise.
        </p>
      </div>
    </div>
  </section>

  <!-- POURQUOI CHOISIR DTS -->
  <section style="padding:4rem 1.25rem;background:linear-gradient(180deg,#060d16 0%,#040c0a 100%);">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;">NOTRE DIFFÉRENCE</p>
        <h2 class="section-title">Pourquoi choisir DTS Dépannage Elec ?</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">
        {[
          { title: "Tarif affiché", desc: "Prix HT communiqués dès le premier appel. Vous savez exactement ce que vous allez payer avant notre arrivée. Aucune majoration cachée, aucune surprise sur la facture.", icon: "📋" },
          { title: "Devis avant travaux", desc: "Systématiquement. Un devis signé est établi avant toute intervention. Vous donnez votre accord écrit avant que nous commencions — c'est votre protection.", icon: "✍️" },
          { title: "Suivi J+1", desc: "Nous rappelons le lendemain de l'intervention pour nous assurer que tout fonctionne correctement. Un service rare dans l'urgence, mais essentiel pour notre qualité.", icon: "📞" },
          { title: "Zone complète couverte", desc: "Seul prestataire à couvrir l'ensemble de la zone franco-suisse (côté français) avec un tarif affiché. Du Pays de Gex à Annecy, de Thonon à Bellegarde.", icon: "🗺️" },
        ].map(e => (
          <div class="card" style="padding:1.75rem;">
            <div style="font-size:2rem;margin-bottom:0.75rem;">{e.icon}</div>
            <h3 style="color:#b8d400;font-weight:700;font-size:1.05rem;margin:0 0 0.5rem;text-shadow:0 0 6px rgba(184,212,0,0.4);">{e.title}</h3>
            <p style="color:#6a9a7a;font-size:0.88rem;margin:0;line-height:1.6;">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
