---
import Layout from '../../layouts/Layout.astro';

const PHONE_DISPLAY = "09 80 80 25 21";
const PHONE_TEL     = "tel:0980802521";

const city = "Saint-Julien-en-Genevois";
const dept = "74";
const nearby = ["Archamps", "Viry", "Valleiry", "Beaumont", "Collonges-sous-Salève", "Présilly", "Dingy-en-Vuache"];
const note = "Sous-préfecture de Haute-Savoie, fort développement résidentiel";

const tarifsJournee = [
  { prestation: "Déplacement",                prix: "75 € HT" },
  { prestation: "Recherche de panne",          prix: "195 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "90 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "130 € HT" },
];
const tarifsNuit = [
  { prestation: "Déplacement",                prix: "115 € HT" },
  { prestation: "Recherche de panne",          prix: "230 € HT" },
  { prestation: "Main d'œuvre / heure",        prix: "150 € HT" },
  { prestation: "Mise en sécurité électrique", prix: "145 € HT" },
];
---

<Layout
  title={`Électricien Urgence ${city} — DTS Dépannage Elec | 24h/24 7j/7`}
  description={`Électricien urgence à ${city} (${dept}) ? DTS Dépannage Elec intervient rapidement 24h/24 7j/7. Tarif affiché, devis avant travaux. Appelez maintenant.`}
>
  <div style="position:sticky;top:0;z-index:50;background:rgba(6,13,22,0.97);border-bottom:1px solid rgba(184,212,0,0.25);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.55rem 1rem;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0.5rem 1.25rem;text-align:center;">
      <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:#c8e0c8;"><span class="pulse-dot"></span><span style="color:#b8d400;font-weight:700;">Disponible 24h/24 — 7j/7</span></span>
      <span style="font-size:0.8rem;color:#c8e0c8;">⚡ Intervention rapide à {city}</span>
      <a href={PHONE_TEL} style="background:#b8d400;color:#060d16;font-weight:800;padding:0.3rem 0.85rem;border-radius:0.4rem;font-size:0.82rem;text-decoration:none;white-space:nowrap;box-shadow:0 0 12px rgba(184,212,0,0.45);">📞 {PHONE_DISPLAY}</a>
    </div>
  </div>
  <nav style="background:rgba(6,13,22,0.95);border-bottom:1px solid rgba(184,212,0,0.08);backdrop-filter:blur(8px);">
    <div style="max-width:1200px;margin:0 auto;padding:0.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;"><img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="54" height="42" style="width:54px;height:42px;object-fit:contain;display:block;transform:translateY(-2px);" /></div>
        <div><div style="color:#b8d400;font-weight:800;font-size:0.95rem;line-height:1.1;text-shadow:0 0 8px rgba(184,212,0,0.6);">DTS Dépannage</div><div style="color:#4a7a5a;font-size:0.72rem;line-height:1;">Elec · 24h/24</div></div>
      </a>
      <div style="display:none;gap:1.5rem;align-items:center;" class="nav-links">
        <a href="/depannage-electricite/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Dépannage</a>
        <a href="/tarifs/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Tarifs</a>
        <a href="/zones/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Zones</a>
        <a href="/contact/" style="color:#c8e0c8;text-decoration:none;font-size:0.88rem;" onmouseover="this.style.color='#b8d400'" onmouseout="this.style.color='#c8e0c8'">Contact</a>
      </div>
      <a href={PHONE_TEL} class="btn-cta" style="padding:0.6rem 1rem;font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        <span class="nav-phone-hide">Appeler — </span>{PHONE_DISPLAY}
      </a>
    </div>
  </nav>
  <section style="position:relative;overflow:hidden;padding:3.5rem 1.25rem 4rem;background:linear-gradient(160deg,#060d16 0%,#071408 60%,#060d16 100%);">
    <svg style="position:absolute;top:8%;left:6%;opacity:0.05;pointer-events:none;" width="60" height="100" viewBox="0 0 60 100" fill="#b8d400"><polygon points="35,0 15,55 30,55 10,100 50,40 33,40"/></svg>
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(184,212,0,0.08);border:1px solid rgba(184,212,0,0.3);border-radius:2rem;padding:0.45rem 1rem;margin-bottom:1.5rem;">
        <span class="pulse-dot"></span>
        <span style="color:#b8d400;font-weight:700;font-size:0.88rem;">Disponible maintenant à {city}</span>
      </div>
      <h1 style="font-size:clamp(1.75rem,5vw,2.8rem);font-weight:900;line-height:1.15;margin:0 0 1.25rem;color:#f0f8f0;">
        Électricien Urgence <span class="neon-green">{city}</span> —<br>Intervention Rapide 24h/24
      </h1>
      <p style="font-size:1.05rem;color:#8ab89a;margin:0 0 0.75rem;line-height:1.7;max-width:680px;margin-left:auto;margin-right:auto;">
        <strong style="color:#c8e0c8;">{note}.</strong> DTS Dépannage Elec intervient sur Saint-Julien-en-Genevois et toutes les communes environnantes pour tout dépannage électrique d'urgence. Tarif affiché dès le premier appel, devis signé avant tous travaux.
      </p>
      <p style="font-size:0.9rem;color:#6a9a7a;margin:0 0 2rem;line-height:1.6;max-width:580px;margin-left:auto;margin-right:auto;">Saint-Julien-en-Genevois est une sous-préfecture en plein essor, avec de nombreux programmes résidentiels récents et une population frontalière en forte croissance. Nous intervenons sur tous types d'installations, récentes ou anciennes.</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.875rem;justify-content:center;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.1rem;padding:1.1rem 2rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Appelez maintenant — {PHONE_DISPLAY}
        </a>
        
      </div>
    </div>
  </section>
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="color:#b8d400;font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 0.5rem;">DÉPANNAGE UNIQUEMENT</p>
        <h2 class="section-title">Services disponibles à {city}</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="services-grid">
        {[
          { title: "Panne générale", desc: "Coupure totale de courant, tableau en défaut. Diagnostic complet et remise en service." },
          { title: "Disjoncteur sauté", desc: "Différentiel qui saute, sectionneur défaillant. Identification de la cause et réparation." },
          { title: "Tableau électrique", desc: "Remplacement, mise aux normes, ajout de protections différentielles." },
          { title: "Prises & éclairage", desc: "Prise HS, court-circuit, interrupteur défaillant. Réparation immédiate sur place." },
          { title: "Mise en sécurité", desc: "Installation dangereuse, câblage vétuste. Neutralisation et mise en conformité urgente." },
          { title: "Urgence pro", desc: "Commerces, restaurants, copropriétés — intervention prioritaire 24h/24." },
        ].map(s => (
          <div class="card" style="padding:1.25rem;">
            <h3 style="color:#f0f8f0;font-size:0.95rem;font-weight:700;margin:0 0 0.4rem;">{s.title}</h3>
            <p style="color:#6a9a7a;font-size:0.82rem;margin:0;line-height:1.5;">{s.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/depannage-electricite/" style="color:#4ab3ff;font-size:0.9rem;text-decoration:none;border-bottom:1px solid rgba(74,179,255,0.3);">En savoir plus sur notre service de dépannage →</a>
      </div>
    </div>
  </section>
  <section style="padding:3rem 1.25rem;background:linear-gradient(180deg,#060d16 0%,#040c0a 100%);">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="card" style="padding:1.75rem;">
        <h2 style="color:#4ab3ff;font-size:1.1rem;font-weight:800;margin:0 0 1rem;text-shadow:0 0 8px rgba(74,179,255,0.5);">Communes couvertes autour de {city}</h2>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-wrap:wrap;gap:0.6rem;">
          {nearby.map(v => (<li style="display:flex;align-items:center;gap:0.3rem;font-size:0.85rem;color:#8ab89a;background:rgba(184,212,0,0.05);border:1px solid rgba(184,212,0,0.1);padding:0.25rem 0.75rem;border-radius:0.4rem;"><span style="width:5px;height:5px;background:#b8d400;border-radius:50%;flex-shrink:0;box-shadow:0 0 4px rgba(184,212,0,0.7);"></span>{v}</li>))}
        </ul>
        <p style="color:#4a7a5a;font-size:0.82rem;margin:1rem 0 0;padding-top:0.75rem;border-top:1px solid rgba(184,212,0,0.1);">Vous êtes dans une autre commune ? Appelez-nous — nous couvrons toute la zone.</p>
      </div>
    </div>
  </section>
  <section style="padding:4rem 1.25rem;background:#060d16;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2rem;">
        <h2 class="section-title">Tarifs à {city}</h2>
        <p style="color:#6a9a7a;font-size:0.9rem;max-width:480px;margin:0.5rem auto 0;">Consultez la <a href="/tarifs/" style="color:#4ab3ff;text-decoration:none;">page tarifs</a> pour le détail complet.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;">
        <div class="card" style="overflow:hidden;">
          <div style="background:rgba(184,212,0,0.08);padding:1rem 1.25rem;border-bottom:1px solid rgba(184,212,0,0.15);display:flex;align-items:center;gap:0.5rem;"><span style="font-size:1.2rem;">☀️</span><div style="color:#b8d400;font-weight:800;font-size:0.95rem;">Journée — 7h à 19h</div></div>
          <table class="tarif-table"><thead><tr><th>Prestation</th><th style="text-align:right;">Prix HT</th></tr></thead><tbody>{tarifsJournee.map(t => (<tr><td>{t.prestation}</td><td>{t.prix}</td></tr>))}</tbody></table>
        </div>
        <div class="card" style="overflow:hidden;">
          <div style="background:rgba(74,179,255,0.06);padding:1rem 1.25rem;border-bottom:1px solid rgba(74,179,255,0.15);display:flex;align-items:center;gap:0.5rem;"><span style="font-size:1.2rem;">🌙</span><div style="color:#4ab3ff;font-weight:800;font-size:0.95rem;">Nuit — 19h à 7h</div></div>
          <table class="tarif-table"><thead><tr><th style="color:#4ab3ff;">Prestation</th><th style="text-align:right;color:#4ab3ff;">Prix HT</th></tr></thead><tbody>{tarifsNuit.map(t => (<tr><td>{t.prestation}</td><td style="color:#4ab3ff;">{t.prix}</td></tr>))}</tbody></table>
        </div>
      </div>
      <p style="text-align:center;color:#4a7a5a;font-size:0.8rem;margin-top:1rem;line-height:1.6;">Devis signé avant tous travaux. TVA en vigueur applicable. CB (TPE) ou espèces.</p>
    </div>
  </section>
  <section style="padding:4rem 1.25rem;background:linear-gradient(135deg,#1a2e00 0%,#0f2400 50%,#0a1e00 100%);border-top:1px solid rgba(184,212,0,0.2);border-bottom:1px solid rgba(184,212,0,0.2);">
    <div style="max-width:700px;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:1.25rem;"><span class="pulse-dot"></span><span style="color:#b8d400;font-weight:700;font-size:0.9rem;">Disponible maintenant à {city}</span></div>
      <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#f0f8f0;margin:0 0 0.75rem;">Urgence électrique à {city} ?</h2>
      <p style="color:#8ab89a;font-size:1.05rem;margin:0 0 2rem;line-height:1.6;">Appelez maintenant — tarif annoncé dès le 1er appel, devis signé avant toute intervention.</p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
        <a href={PHONE_TEL} class="btn-cta" style="font-size:1.2rem;padding:1.1rem 2.25rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {PHONE_DISPLAY}
        </a>
        
      </div>
    </div>
  </section>
  <div class="floating-cta" role="complementary" aria-label="Appel rapide">
    <a href={PHONE_TEL} class="tel">📞 {PHONE_DISPLAY}</a>
  </div>
  <footer style="background:#030a0f;border-top:1px solid rgba(184,212,0,0.1);padding:3rem 1.25rem 2rem;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;margin-bottom:2rem;">
        <div>
          <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.875rem;"><div style="background:#fff;border-radius:7px;padding:4px;flex-shrink:0;"><img src="/images/logo-dts.png" alt="DTS Dépannage Elec" width="48" height="38" style="width:48px;height:38px;object-fit:contain;display:block;transform:translateY(-2px);" /></div><div><div style="color:#b8d400;font-weight:800;font-size:0.9rem;">DTS Dépannage Elec</div><div style="color:#4a7a5a;font-size:0.7rem;">Urgence 24h/24 — 7j/7</div></div></div>
          <p style="color:#4a7a5a;font-size:0.82rem;line-height:1.6;margin:0;">Électricien urgence sur la zone franco-suisse. Tarif affiché, devis avant travaux.</p>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Liens utiles</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li><a href="/depannage-electricite/" style="color:#4a7a5a;font-size:0.82rem;text-decoration:none;">Service de dépannage</a></li>
            <li><a href="/tarifs/" style="color:#4a7a5a;font-size:0.82rem;text-decoration:none;">Tarifs</a></li>
            <li><a href="/zones/" style="color:#4a7a5a;font-size:0.82rem;text-decoration:none;">Zones</a></li>
            <li><a href="/contact/" style="color:#4a7a5a;font-size:0.82rem;text-decoration:none;">Contact</a></li>
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Zones</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
            {["Pays de Gex (01)", "Annemasse +40 km", "Thonon +20 km", "Annecy +40 km", "Bellegarde +20 km"].map(z => (<li style="color:#4a7a5a;font-size:0.82rem;">{z}</li>))}
          </ul>
        </div>
        <div>
          <h3 style="color:#b8d400;font-size:0.85rem;font-weight:700;margin:0 0 0.875rem;text-transform:uppercase;letter-spacing:0.08em;">Contact</h3>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <a href={PHONE_TEL} style="color:#c8e0c8;font-size:0.88rem;text-decoration:none;display:flex;align-items:center;gap:0.4rem;">📞 <span>{PHONE_DISPLAY}</span></a>
            <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.25rem;"><span class="pulse-dot" style="width:7px;height:7px;"></span><span style="color:#b8d400;font-size:0.82rem;font-weight:600;">Disponible maintenant</span></div>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid rgba(184,212,0,0.08);padding-top:1.25rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:space-between;align-items:center;">
        <p style="color:#2a4a3a;font-size:0.75rem;margin:0;">© 2025 DTS Dépannage Elec — Déco Travaux Services. Entreprise française.</p>
        <div style="display:flex;gap:1rem;"><a href="/tarifs/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Tarifs</a><a href="/zones/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Zones</a><a href="/contact/" style="color:#2a4a3a;font-size:0.75rem;text-decoration:none;">Contact</a></div>
      </div>
    </div>
  </footer>
</Layout>
<style>
  .nav-phone-hide { display: none; }
  @media (min-width: 700px) { .nav-links { display: flex !important; } }
  @media (min-width: 900px) { .nav-phone-hide { display: inline !important; } .services-grid { grid-template-columns: repeat(3, 1fr) !important; } }
</style>
